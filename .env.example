# --- Bootstrap (still use .env for these) ---
# The bot SQLite file must be known before we can read dashboard-stored settings.
# DATABASE_URL=sqlite:////absolute/path/nothing_happens.sqlite
# Or: NOTHING_HAPPENS_SQLITE_PATH=data/nothing_happens.sqlite
#
# Dashboard login (≥32 chars for secret). Public dashboard needs bind + auth:
# DASHBOARD_AUTH_SECRET=
# DASHBOARD_AUTH_DB_PATH=dashboard_auth.sqlite
# DASHBOARD_HOST=127.0.0.1
# DASHBOARD_PORT=8891
# DASHBOARD_BOOTSTRAP_USERNAME=
# DASHBOARD_BOOTSTRAP_PASSWORD=
#
# Config file path for defaults until the DB is seeded (default: config.json)
# CONFIG_PATH=config.json

# --- Optional: legacy env overrides ---
# When the runtime_settings table is empty, the bot behaves as before (env + config.json).
# After the first startup seeds rows (or you use Admin → Settings), values in SQLite win at
# process startup. You can remove the variables below from .env once they are stored in the DB.
#
# BOT_MODE=paper
# DRY_RUN=true
# LIVE_TRADING_ENABLED=false
# PRIVATE_KEY=
# FUNDER_ADDRESS=
# POLYGON_RPC_URL=
# PM_CONNECTION_HOST=
# PM_CONNECTION_CHAIN_ID=
# PM_CONNECTION_SIGNATURE_TYPE=
# TRADE_LEDGER_PATH=trades.jsonl
# LOG_LEVEL=INFO
# Plus PM_NH_* and PM_RISK_* — see Admin → Settings in the dashboard.
# ETA / discovery (optional): PM_NH_MAX_END_DATE_MONTHS, PM_NH_MIN_RESOLUTION_ETA_SEC,
# PM_NH_MAX_RESOLUTION_ETA_SEC — see docs/strategy-parameters.md
#
# Optional: web-triggered restart (see docs/deployment.md — requires cron + scripts/neh_cron_restart.sh)
# NEH_RESTART_FLAG_PATH=data/.neh_restart_requested
#
# --- Dashboard backtest job queue (Phase 3) ---
# Set to enable /admin/backtest + /api/backtest/* on the dashboard app.
# BACKTEST_UI=1
# BACKTEST_JOB_DIR=var/backtest-jobs
# BACKTEST_MAX_CONCURRENT=2
# BACKTEST_MAX_PER_USER_PER_HOUR=20
# BACKTEST_ENFORCE_LOCAL_ONLY=1
# Optional dataset registry: JSON list of {id,path,label} or scan BACKTEST_ARCHIVE_ROOT for archives with universe.parquet
# BACKTEST_DATASETS_JSON=[{"id":"demo","path":"/abs/path/archive","label":"demo"}]
# BACKTEST_ARCHIVE_ROOT=/abs/path/archives_parent
