# Deployment mode (secrets and toggles only — everything else is in config.json)
BOT_MODE=paper
DRY_RUN=true
LIVE_TRADING_ENABLED=false

# Secrets
PRIVATE_KEY=
# Required for signature_type 1 or 2 live accounts
FUNDER_ADDRESS=
# Required for BOT_MODE=live
DATABASE_URL=
# Required for proxy-wallet approval bootstrap in live signature_type=2 mode
POLYGON_RPC_URL=

# Config file path (default: config.json)
# CONFIG_PATH=config.json

# Dashboard (when PORT or DASHBOARD_PORT is set)
# If DASHBOARD_AUTH_SECRET is set (≥32 chars), /login is required; admin users live in
# Postgres (same DATABASE_URL as the bot, or override with DASHBOARD_AUTH_DATABASE_URL).
# DASHBOARD_AUTH_SECRET=
# DASHBOARD_AUTH_DATABASE_URL=
# Optional one-time bootstrap when admin table is empty:
# DASHBOARD_BOOTSTRAP_USERNAME=
# DASHBOARD_BOOTSTRAP_PASSWORD=
