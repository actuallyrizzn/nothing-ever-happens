# Deployment mode (secrets and toggles only — everything else is in config.json)
BOT_MODE=paper
DRY_RUN=true
LIVE_TRADING_ENABLED=false

# Secrets
PRIVATE_KEY=
# Required for signature_type 1 or 2 live accounts
FUNDER_ADDRESS=
# SQLite for trade_events, recovery tables, etc. (omit to use ./nothing_happens.sqlite)
# DATABASE_URL=sqlite:////absolute/path/nothing_happens.sqlite
# Or set only a filename/path (relative to cwd when the bot starts):
# NOTHING_HAPPENS_SQLITE_PATH=data/nothing_happens.sqlite
# Required for proxy-wallet approval bootstrap in live signature_type=2 mode
POLYGON_RPC_URL=

# Config file path (default: config.json)
# CONFIG_PATH=config.json

# Dashboard (when PORT or DASHBOARD_PORT is set)
# If DASHBOARD_AUTH_SECRET is set (≥32 chars), /login is required; admin users are stored
# in a separate SQLite file from the main bot DB (see DATABASE_URL above).
# DASHBOARD_AUTH_SECRET=
# DASHBOARD_AUTH_DB_PATH=dashboard_auth.sqlite
# Optional one-time bootstrap when DB has zero users:
# DASHBOARD_BOOTSTRAP_USERNAME=
# DASHBOARD_BOOTSTRAP_PASSWORD=
